{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yzh5310/course-review-skill/schemas/question.schema.json",
  "title": "Course Review Generated Question",
  "type": "object",
  "required": ["type", "conceptIds", "learningObjective", "difficulty", "difficultyReason", "question", "answer", "explanation", "hint", "sourceBasis", "diagnosticUse", "targetsMemory", "selfCheck"],
  "properties": {
    "type": { "enum": ["choice", "tf", "calc", "short", "material"] },
    "conceptIds": { "type": "array", "minItems": 1, "maxItems": 2, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "learningObjective": { "type": "string", "minLength": 1 },
    "chapter": { "type": "string" },
    "difficulty": { "enum": ["easy", "medium", "hard"] },
    "difficultyReason": { "type": "string", "minLength": 1 },
    "question": { "type": "string", "minLength": 1 },
    "options": { "type": "array", "minItems": 4, "maxItems": 4, "items": { "type": "string" } },
    "answer": {},
    "explanation": { "type": "string", "minLength": 1 },
    "hint": { "type": "string" },
    "sourceBasis": { "enum": ["source", "derived", "generic"] },
    "diagnosticUse": { "type": "boolean" },
    "suggestedErrorCategory": { "enum": ["concept", "formula", "calc", "method", "read", "prereq", "unknown"] },
    "targetsMemory": {
      "type": "object",
      "required": ["observedNeed"],
      "properties": { "observedNeed": { "type": "string" } },
      "additionalProperties": false
    },
    "selfCheck": {
      "type": "object",
      "required": ["conditionsSufficient", "answerRecalculated", "uniqueAnswer"],
      "properties": {
        "conditionsSufficient": { "type": "boolean" },
        "answerRecalculated": { "type": "boolean" },
        "uniqueAnswer": { "type": "boolean" },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "choice" } } },
      "then": { "required": ["options"], "properties": { "answer": { "type": "integer", "minimum": 0, "maximum": 3 } } }
    },
    {
      "if": { "properties": { "type": { "const": "tf" } } },
      "then": { "properties": { "answer": { "type": "boolean" } } }
    }
  ],
  "additionalProperties": false
}
